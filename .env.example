# Local development defaults
PORT=8080
DATABASE_URL=postgresql://localhost:5432/kahani
LOG_LEVEL=info

# Local mobile app
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_DOMAIN=localhost:8081
EXPO_PUBLIC_REPL_ID=

# Clerk auth. Leave blank to skip auth in local mobile development.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_PROXY_URL=

# AI story generation. Required for real story generation through the API.
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_INTEGRATIONS_OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_MODEL=openai/gpt-5.4-nano
AI_INTEGRATIONS_OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Optional OpenRouter attribution headers. Used only when calling OpenRouter.
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Kahani

# Mockup sandbox
MOCKUP_PORT=8081
BASE_PATH=/
